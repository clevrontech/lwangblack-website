{
  "openapi": "3.0.3",
  "info": {
    "title": "Lwang Black API",
    "description": "E-commerce backend API for Lwang Black specialty coffee. Supports multi-currency payments (Stripe, PayPal, Khalti, eSewa, Nabil Bank), global logistics (Shippo, DHL, FedEx), admin dashboard, and notification services.",
    "version": "1.0.0",
    "contact": {
      "email": "brewed@lwangblack.co",
      "url": "https://www.lwangblack.co"
    }
  },
  "servers": [
    { "url": "http://localhost:3001", "description": "Local development" },
    { "url": "https://api.lwangblack.co", "description": "Production" }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication and session management" },
    { "name": "Products", "description": "Product catalog CRUD" },
    { "name": "Orders", "description": "Order management" },
    { "name": "Payments", "description": "Payment initiation, verification, and refunds" },
    { "name": "Logistics", "description": "Shipping rates, tracking, and delivery zones" },
    { "name": "Notifications", "description": "Email/SMS notifications and invoice generation" },
    { "name": "Cart", "description": "Cart persistence" },
    { "name": "Customers", "description": "Customer database" },
    { "name": "Analytics", "description": "Sales and traffic analytics" },
    { "name": "Settings", "description": "Store configuration" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "LB-2450" },
          "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled", "refunded"] },
          "country": { "type": "string", "example": "AU" },
          "currency": { "type": "string", "example": "AUD" },
          "symbol": { "type": "string", "example": "A$" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } },
          "subtotal": { "type": "number" },
          "shipping": { "type": "number" },
          "total": { "type": "number" },
          "customer": { "$ref": "#/components/schemas/Customer" },
          "payment": { "type": "object" },
          "date": { "type": "string", "format": "date-time" }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "qty": { "type": "integer" },
          "price": { "type": "number" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string", "enum": ["coffee", "accessories", "bundles", "apparel"] },
          "description": { "type": "string" },
          "prices": { "type": "object" },
          "stock": { "type": "integer" },
          "status": { "type": "string", "enum": ["active", "draft", "archived"] }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "fname": { "type": "string" },
          "lname": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "country": { "type": "string" }
        }
      },
      "DeliveryZone": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "country": { "type": "string" },
          "shipping_cost": { "type": "number" },
          "currency": { "type": "string" },
          "free_above": { "type": "number", "nullable": true },
          "estimated_days": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Admin login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "JWT tokens returned" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "New tokens" } }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout (revoke session)",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Session revoked" } }
      }
    },
    "/api/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List all products",
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Product list with Redis caching" }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create a product",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Product" }
            }
          }
        },
        "responses": { "201": { "description": "Product created" } }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product by ID or slug",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Product details" }, "404": { "description": "Not found" } }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Update a product",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Archive a product (owner only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Archived" } }
      }
    },
    "/api/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "List orders (filtered by role/country)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "country", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": { "200": { "description": "Paginated order list" } }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Create a new order",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "country": { "type": "string" },
                  "currency": { "type": "string" },
                  "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } },
                  "subtotal": { "type": "number" },
                  "shipping": { "type": "number" },
                  "total": { "type": "number" },
                  "customer": { "$ref": "#/components/schemas/Customer" },
                  "paymentMethod": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Order created with auto-generated invoice" } }
      }
    },
    "/api/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order details",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Order with transactions" } }
      },
      "patch": {
        "tags": ["Orders"],
        "summary": "Update order status (triggers notifications)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled", "refunded"] },
                  "tracking": { "type": "string" },
                  "carrier": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Order updated" } }
      },
      "delete": {
        "tags": ["Orders"],
        "summary": "Cancel an order",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Order cancelled" } }
      }
    },
    "/api/payments/demo-confirm": {
      "post": {
        "tags": ["Payments"],
        "summary": "Simulate payment in demo mode (no real API keys)",
        "description": "When payment gateways are not configured, use this endpoint to simulate a successful payment and move the order from pending to paid.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["orderId"],
                "properties": {
                  "orderId": { "type": "string", "example": "LB-123456" },
                  "method": { "type": "string", "example": "stripe", "description": "Payment method to record" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order marked as paid, confirmation email and invoice triggered" }
        }
      }
    },
    "/api/payments/methods": {
      "get": {
        "tags": ["Payments"],
        "summary": "Get available payment methods by country",
        "parameters": [{ "name": "country", "in": "query", "schema": { "type": "string", "default": "US" } }],
        "responses": { "200": { "description": "Payment methods list" } }
      }
    },
    "/api/payments/stripe-session": {
      "post": {
        "tags": ["Payments"],
        "summary": "Create Stripe checkout session",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": { "type": "array" },
                  "country": { "type": "string" },
                  "orderId": { "type": "string" },
                  "customerEmail": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Stripe session URL" } }
      }
    },
    "/api/payments/paypal-create": {
      "post": {
        "tags": ["Payments"],
        "summary": "Create PayPal order",
        "responses": { "200": { "description": "PayPal approval URL" } }
      }
    },
    "/api/payments/khalti-initiate": {
      "post": {
        "tags": ["Payments"],
        "summary": "Initiate Khalti payment (Nepal)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["orderId", "amount"],
                "properties": {
                  "orderId": { "type": "string" },
                  "amount": { "type": "number", "description": "Amount in NPR" },
                  "customerName": { "type": "string" },
                  "customerEmail": { "type": "string" },
                  "customerPhone": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Khalti payment URL and pidx" } }
      }
    },
    "/api/payments/esewa-initiate": {
      "post": {
        "tags": ["Payments"],
        "summary": "Initiate eSewa payment (Nepal)",
        "responses": { "200": { "description": "eSewa gateway URL and form data" } }
      }
    },
    "/api/payments/nabil-initiate": {
      "post": {
        "tags": ["Payments"],
        "summary": "Initiate Nabil Bank payment (Nepal)",
        "responses": { "200": { "description": "Nabil Bank gateway URL" } }
      }
    },
    "/api/payments/{orderId}/refund": {
      "post": {
        "tags": ["Payments"],
        "summary": "Process refund (Stripe/PayPal auto-refund supported)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Refund processed with email notification" } }
      }
    },
    "/api/payments/status/{orderId}": {
      "get": {
        "tags": ["Payments"],
        "summary": "Check payment status for an order",
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Payment status" } }
      }
    },
    "/api/logistics/carriers": {
      "get": {
        "tags": ["Logistics"],
        "summary": "List supported carriers",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Carrier list (DHL, FedEx, UPS, Shippo, Sajilo, Aramex)" } }
      }
    },
    "/api/logistics/zones": {
      "get": {
        "tags": ["Logistics"],
        "summary": "List delivery zones with pricing",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Delivery zones (Kathmandu free, global paid)" } }
      }
    },
    "/api/logistics/rates": {
      "post": {
        "tags": ["Logistics"],
        "summary": "Get shipping rates (Shippo API with zone fallback)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "toCountry": { "type": "string" },
                  "toCity": { "type": "string" },
                  "toZip": { "type": "string" },
                  "weight": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Rate quotes from carriers" } }
      }
    },
    "/api/logistics/create-shipment": {
      "post": {
        "tags": ["Logistics"],
        "summary": "Create shipment and generate tracking (Shippo label purchase)",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Tracking number, label URL, notifications sent" } }
      }
    },
    "/api/logistics/track": {
      "post": {
        "tags": ["Logistics"],
        "summary": "Track a shipment",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["trackingNumber"],
                "properties": {
                  "trackingNumber": { "type": "string" },
                  "carrierId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Tracking events and status" } }
      }
    },
    "/api/logistics/shipping-cost": {
      "post": {
        "tags": ["Logistics"],
        "summary": "Calculate shipping cost from delivery zones",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Shipping cost with zone info" } }
      }
    },
    "/api/logistics/admin-override": {
      "post": {
        "tags": ["Logistics"],
        "summary": "Admin override shipping cost for an order",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Shipping cost overridden" } }
      }
    },
    "/api/notifications/log": {
      "get": {
        "tags": ["Notifications"],
        "summary": "View notification history (email/SMS)",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Notification log entries" } }
      }
    },
    "/api/notifications/send-email": {
      "post": {
        "tags": ["Notifications"],
        "summary": "Send manual email (SendGrid)",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Email sent" } }
      }
    },
    "/api/notifications/send-sms": {
      "post": {
        "tags": ["Notifications"],
        "summary": "Send manual SMS (Twilio)",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "SMS sent" } }
      }
    },
    "/api/notifications/invoice/{orderId}": {
      "post": {
        "tags": ["Notifications"],
        "summary": "Generate and optionally email invoice PDF",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Invoice generated" } }
      },
      "get": {
        "tags": ["Notifications"],
        "summary": "Get invoice for an order",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Invoice details" } }
      }
    },
    "/api/cart": {
      "get": {
        "tags": ["Cart"],
        "summary": "Load persisted cart (Redis-backed)",
        "responses": { "200": { "description": "Cart items" } }
      },
      "post": {
        "tags": ["Cart"],
        "summary": "Save cart (tracks abandoned carts)",
        "responses": { "200": { "description": "Cart saved" } }
      },
      "delete": {
        "tags": ["Cart"],
        "summary": "Clear cart",
        "responses": { "200": { "description": "Cart cleared" } }
      }
    },
    "/api/customers": {
      "get": {
        "tags": ["Customers"],
        "summary": "List customers with search",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Customer list" } }
      }
    },
    "/api/settings": {
      "get": {
        "tags": ["Settings"],
        "summary": "Get store settings",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Key-value settings" } }
      },
      "put": {
        "tags": ["Settings"],
        "summary": "Update store settings (owner only)",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Settings saved" } }
      }
    },
    "/api/checkout-config": {
      "get": {
        "tags": ["Settings"],
        "summary": "Public checkout config with GDPR policy links",
        "responses": { "200": { "description": "Policy URLs and GDPR consent message" } }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["Settings"],
        "summary": "Health check",
        "responses": { "200": { "description": "Server status, uptime, WebSocket clients" } }
      }
    }
  }
}
