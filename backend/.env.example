# ── Lwang Black Backend — All Environment Variables ────────────────────────
# Copy this file to .env and fill in your real values

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://lwangblack:lwangblack_secret@localhost:5432/lwangblack
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lwangblack
DB_USER=lwangblack
DB_PASSWORD=lwangblack_secret

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-too
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe (Payment Gateway + Manager Subscriptions) ─────────────────────────
# Get from: https://dashboard.stripe.com/developers/api-keys
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# For manager subscription ($1999/month) webhook — set in Stripe Dashboard:
# Webhook URL: https://yourdomain.com/api/subscription/webhook
# Events: customer.subscription.created, customer.subscription.updated,
#         customer.subscription.deleted, invoice.payment_failed

# ── PayPal ───────────────────────────────────────────────────────────────────
# Get from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=paypal_client_placeholder
PAYPAL_CLIENT_SECRET=paypal_secret_placeholder
PAYPAL_LIVE=false

# ── eSewa (Nepal) ────────────────────────────────────────────────────────────
# Get from: https://esewa.com.np/epay/main
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_LIVE=false

# ── Nabil Bank (Nepal) ───────────────────────────────────────────────────────
# Get from: https://nabilbank.com/developer
NABIL_MERCHANT_ID=
NABIL_API_KEY=
NABIL_SECRET_KEY=
NABIL_LIVE=false

# ── Logistics APIs ───────────────────────────────────────────────────────────
# DHL — https://developer.dhl.com/
DHL_API_KEY=
DHL_ACCOUNT_NUMBER=
DHL_LIVE=false

# FedEx — https://developer.fedex.com/
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_LIVE=false

# UPS — https://developer.ups.com/
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_LIVE=false

# Ship24 (Universal Tracking) — https://www.ship24.com/api
SHIP24_API_KEY=

# Shippo — https://goshippo.com/api/
SHIPPO_API_KEY=

# Australia Post — https://developers.auspost.com.au/
AUSPOST_API_KEY=

# ── Social Media ─────────────────────────────────────────────────────────────
# Facebook & Instagram — https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PIXEL_ID=

# Instagram (uses same Facebook App)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=

# TikTok — https://developers.tiktok.com/
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.placeholder
SENDGRID_FROM_EMAIL=brewed@lwangblack.co
SENDGRID_FROM_NAME=Lwang Black

# ── Site ─────────────────────────────────────────────────────────────────────
SITE_URL=https://www.lwangblack.co
CORS_ORIGIN=https://www.lwangblack.co,http://localhost:3000

# ── Admin ────────────────────────────────────────────────────────────────────
DEFAULT_ADMIN_PASSWORD=lwangblack2024
# Owner is never restricted. Managers need $1999/month subscription.
MANAGER_SUBSCRIPTION_PRICE=1999
MANAGER_SUBSCRIPTION_TRIAL_DAYS=7
